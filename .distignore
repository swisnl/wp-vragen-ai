# Files excluded from the WordPress.org package.
# vendor/ is intentionally NOT listed: it is built with `composer install --no-dev`
# before deploy and must ship inside the plugin.
/.git
/.github
/.wordpress-org
/.gitattributes
/.gitignore
/.distignore
/.editorconfig
/README.md
/node_modules
/stubs
/tests
/phpunit.xml.dist
/.phpunit.cache
/phpstan.neon.dist
/phpstan-baseline.neon
/composer.json
/composer.lock
.DS_Store
.idea
