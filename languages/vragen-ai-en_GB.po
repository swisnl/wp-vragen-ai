msgid "SWIS"
msgstr ""

#: src/Admin.php:112
msgid "Vragen.ai instellingen"
msgstr "Vragen.ai settings"

#. translators: %s: API error message
#: src/Admin.php:119
#, php-format
msgid "Verbinding met vragen.ai mislukt: %s"
msgstr "Connection to vragen.ai failed: %s"

#: src/Admin.php:125
msgid "Verbonden met vragen.ai."
msgstr "Connected to vragen.ai."

#. translators: %d: number of posts queued
#: src/Admin.php:134
#, php-format
msgid "%d posts in de wachtrij geplaatst voor synchronisatie."
msgstr "%d posts queued for synchronisation."

#: src/Admin.php:145
msgid "Klantnaam"
msgstr "Customer name"

#: src/Admin.php:153
msgid "Ingesteld via de constante VRAGENAI_CUSTOMER in wp-config.php."
msgstr "Set via the VRAGENAI_CUSTOMER constant in wp-config.php."

#. translators: %s: API root domain, e.g. vragen.ai
#: src/Admin.php:157
#, php-format
msgid "Subdomein van {klantnaam}.%s"
msgstr "Subdomain of {customer}.%s"

#: src/Admin.php:165
msgid "API-token"
msgstr "API token"

#: src/Admin.php:172
msgid "Ingesteld via de constante VRAGENAI_TOKEN in wp-config.php."
msgstr "Set via the VRAGENAI_TOKEN constant in wp-config.php."

#: src/Admin.php:174
msgid "Er is een token opgeslagen. Laat dit veld leeg om het te behouden."
msgstr "A token is stored. Leave this field empty to keep it."

#: src/Admin.php:176
msgid "Het API-token van vragen.ai."
msgstr "The vragen.ai API token."

#: src/Admin.php:182
msgid "Te synchroniseren contenttypen"
msgstr "Content types to synchronise"

#: src/Admin.php:198
msgid "Globale embed"
msgstr "Global embed"

#: src/Admin.php:203
msgid "— Geen —"
msgstr "— None —"

#: src/Admin.php:215
msgid "Optioneel. Laadt een popup- of popover-deployment site-breed. Laat leeg om uit te schakelen. Gebruik voor pagina-embeds het blok \"Vragen.ai embed\"."
msgstr "Optional. Loads a popup or popover deployment site-wide. Leave empty to disable. For page embeds, use the \"Vragen.ai embed\" block."

#: src/Admin.php:260
msgid "Instellingen opslaan"
msgstr "Save settings"

#: src/Admin.php:264
msgid "Bulk-synchronisatie"
msgstr "Bulk synchronisation"

#: src/Admin.php:265
msgid "Synchroniseer alle gepubliceerde content naar vragen.ai. Posts worden via de wachtrij verwerkt."
msgstr "Synchronise all published content to vragen.ai. Posts are processed via the queue."

#: src/Admin.php:269
msgid "Bulk-synchronisatie starten"
msgstr "Start bulk synchronisation"

#: src/Admin.php:278
msgid "Geen toegang."
msgstr "Access denied."

#: src/Embed.php:135
msgid "Vragen.ai: voer een deployment-slug in."
msgstr "Vragen.ai: enter a deployment slug."

#: blocks/embed/edit.js:80
msgid "Selecteer een deployment…"
msgstr "Select a deployment…"

#: blocks/embed/edit.js:89
msgid "Deployment"
msgstr "Deployment"

#: blocks/embed/edit.js:100
msgid "Deployment-slug"
msgstr "Deployment slug"

#: blocks/embed/edit.js:104
msgid "Kon de lijst met deployments niet laden. Voer de slug handmatig in."
msgstr "Could not load the list of deployments. Enter the slug manually."

#: blocks/embed/edit.js:105
msgid "Voer de deployment-slug handmatig in."
msgstr "Enter the deployment slug manually."

#: blocks/embed/edit.js:120
msgid "Vragen.ai embed"
msgstr "Vragen.ai embed"

#: blocks/embed/edit.js:121
msgid "Kies de Vragen.ai-deployment om in te sluiten. Het build-type (pagina, popup of popover) komt uit de deployment zelf."
msgstr "Choose the Vragen.ai deployment to embed. The build type (page, popup or popover) comes from the deployment itself."

#: blocks/embed/block.json
msgctxt "block title"
msgid "Vragen.ai embed"
msgstr "Vragen.ai embed"

#: blocks/embed/block.json
msgctxt "block description"
msgid "Embed een Vragen.ai-deployment via de deployment-slug. Het build-type (pagina, popup of popover) komt uit de deployment zelf."
msgstr "Embed a Vragen.ai deployment by its slug. The build type (page, popup or popover) comes from the deployment itself."

#: blocks/embed/block.json
#: blocks/related/block.json
msgctxt "block keyword"
msgid "vragen"
msgstr "questions"

#: blocks/embed/block.json
#: blocks/related/block.json
msgctxt "block keyword"
msgid "ai"
msgstr "ai"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "chat"
msgstr "chat"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "zoeken"
msgstr "search"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "embed"
msgstr "embed"

#: src/Admin.php:220
msgid "Zoeken"
msgstr "Search"

#: src/Admin.php:225
msgid "Vervang de standaard WordPress-zoekfunctie door semantisch zoeken via vragen.ai."
msgstr "Replace the default WordPress search with semantic search via vragen.ai."

#: src/Admin.php:230
msgid "Taalfallback: toon resultaten in de standaardtaal als er geen vertaling in de huidige taal bestaat."
msgstr "Language fallback: show results in the default language when no translation exists in the current language."

#: src/Admin.php:232
msgid "Alleen gesynchroniseerde content is doorzoekbaar. Bij een fout of time-out valt het zoeken automatisch terug op de standaardzoekfunctie van WordPress."
msgstr "Only synchronised content is searchable. On an error or timeout, search automatically falls back to WordPress' built-in search."

#: src/Search/Related.php:69
msgid "Vragen.ai: nog geen gerelateerde content beschikbaar."
msgstr "Vragen.ai: no related content available yet."

#: blocks/related/block.json
msgctxt "block title"
msgid "Vragen.ai gerelateerde content"
msgstr "Vragen.ai related content"

#: blocks/related/block.json
msgctxt "block description"
msgid "Toont content gerelateerd aan de huidige pagina op basis van semantische gelijkenis via Vragen.ai."
msgstr "Shows content related to the current page based on semantic similarity via Vragen.ai."

#: blocks/related/block.json
msgctxt "block keyword"
msgid "gerelateerd"
msgstr "related"

#: blocks/related/block.json
msgctxt "block keyword"
msgid "related"
msgstr "related"

#: blocks/related/block.json
msgctxt "block keyword"
msgid "aanbevolen"
msgstr "recommended"

#: blocks/related/edit.js:67
msgid "Instellingen"
msgstr "Settings"

#: blocks/related/edit.js:69
msgid "Titel"
msgstr "Title"

#: blocks/related/edit.js:71
msgid "Bijv. Gerelateerde content"
msgstr "E.g. Related content"

#: blocks/related/edit.js:78
msgid "Aantal items"
msgstr "Number of items"

#: src/Admin.php:238
msgid "Maximale semantische afstand"
msgstr "Maximum semantic distance"

#: src/Admin.php:244
msgid "Optioneel (0–1). Filtert resultaten met een te grote semantische afstand weg; lager is strenger. Laat leeg voor geen limiet."
msgstr "Optional (0–1). Filters out results whose semantic distance is too large; lower is stricter. Leave empty for no limit."

#: blocks/related/edit.js:88
msgid "Weergave"
msgstr "Display"

#: blocks/related/edit.js:91
msgid "Lijst"
msgstr "List"

#: blocks/related/edit.js:92
msgid "Kaarten"
msgstr "Cards"

#: src/Admin.php:250
msgid "Alpha (semantisch vs. trefwoord)"
msgstr "Alpha (semantic vs. keyword)"

#: src/Admin.php:256
msgid "Optioneel (0–1). Weegt hybride zoeken: 1 = puur semantisch, 0 = puur op trefwoorden. Laat leeg voor de standaard van vragen.ai."
msgstr "Optional (0–1). Weights hybrid search: 1 = purely semantic, 0 = purely keyword-based. Leave empty for the vragen.ai default."
