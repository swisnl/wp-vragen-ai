#. Plugin Name of the plugin
#: vragen-ai.php src/Admin.php:17 src/Admin.php:18
msgid "Vragen.ai"
msgstr ""

#. Description of the plugin
#: vragen-ai.php
msgid "Synchronises WordPress content with the vragen.ai knowledge base."
msgstr ""

#. Author of the plugin
#: vragen-ai.php
msgid "SWIS"
msgstr ""

#: src/Admin.php:94
msgid "Vragen.ai instellingen"
msgstr "Vragen.ai settings"

#. translators: %s: API error message
#: src/Admin.php:101
#, php-format
msgid "Verbinding met vragen.ai mislukt: %s"
msgstr "Connection to vragen.ai failed: %s"

#: src/Admin.php:107
msgid "Verbonden met vragen.ai."
msgstr "Connected to vragen.ai."

#. translators: %d: number of posts queued
#: src/Admin.php:116
#, php-format
msgid "%d posts in de wachtrij geplaatst voor synchronisatie."
msgstr "%d posts queued for synchronisation."

#: src/Admin.php:127
msgid "Klantnaam"
msgstr "Customer name"

#: src/Admin.php:135
msgid "Ingesteld via de constante VRAGENAI_CUSTOMER in wp-config.php."
msgstr "Set via the VRAGENAI_CUSTOMER constant in wp-config.php."

#. translators: %s: API root domain, e.g. vragen.ai
#: src/Admin.php:139
#, php-format
msgid "Subdomein van {klantnaam}.%s"
msgstr "Subdomain of {customer}.%s"

#: src/Admin.php:147
msgid "API-token"
msgstr "API token"

#: src/Admin.php:154
msgid "Ingesteld via de constante VRAGENAI_TOKEN in wp-config.php."
msgstr "Set via the VRAGENAI_TOKEN constant in wp-config.php."

#: src/Admin.php:156
msgid "Er is een token opgeslagen. Laat dit veld leeg om het te behouden."
msgstr "A token is stored. Leave this field empty to keep it."

#: src/Admin.php:158
msgid "Het API-token van vragen.ai."
msgstr "The vragen.ai API token."

#: src/Admin.php:164
msgid "Te synchroniseren contenttypen"
msgstr "Content types to synchronise"

#: src/Admin.php:180
msgid "Globale embed"
msgstr "Global embed"

#: src/Admin.php:185
msgid "— Geen —"
msgstr "— None —"

#: src/Admin.php:197
msgid ""
"Optioneel. Laadt een popup- of popover-deployment site-breed. Laat leeg om "
"uit te schakelen. Gebruik voor pagina-embeds het blok \"Vragen.ai embed\"."
msgstr ""
"Optional. Loads a popup or popover deployment site-wide. Leave empty to "
"disable. For page embeds, use the \"Vragen.ai embed\" block."

#: src/Admin.php:201
msgid "Instellingen opslaan"
msgstr "Save settings"

#: src/Admin.php:205
msgid "Bulk-synchronisatie"
msgstr "Bulk synchronisation"

#: src/Admin.php:206
msgid ""
"Synchroniseer alle gepubliceerde content naar vragen.ai. Posts worden via de "
"wachtrij verwerkt."
msgstr ""
"Synchronise all published content to vragen.ai. Posts are processed via the "
"queue."

#: src/Admin.php:210
msgid "Bulk-synchronisatie starten"
msgstr "Start bulk synchronisation"

#: src/Admin.php:219
msgid "Geen toegang."
msgstr "Access denied."

#: src/Embed.php:135
msgid "Vragen.ai: voer een deployment-slug in."
msgstr "Vragen.ai: enter a deployment slug."

#: blocks/embed/edit.js:80
msgid "Selecteer een deployment…"
msgstr "Select a deployment…"

#: blocks/embed/edit.js:89
msgid "Deployment"
msgstr "Deployment"

#: blocks/embed/edit.js:100
msgid "Deployment-slug"
msgstr "Deployment slug"

#: blocks/embed/edit.js:104
msgid "Kon de lijst met deployments niet laden. Voer de slug handmatig in."
msgstr "Could not load the list of deployments. Enter the slug manually."

#: blocks/embed/edit.js:105
msgid "Voer de deployment-slug handmatig in."
msgstr "Enter the deployment slug manually."

#: blocks/embed/edit.js:120
msgid "Vragen.ai embed"
msgstr "Vragen.ai embed"

#: blocks/embed/edit.js:121
msgid ""
"Kies de Vragen.ai-deployment om in te sluiten. Het build-type (pagina, popup "
"of popover) komt uit de deployment zelf."
msgstr ""
"Choose the Vragen.ai deployment to embed. The build type (page, popup or "
"popover) comes from the deployment itself."

#: blocks/embed/block.json
msgctxt "block title"
msgid "Vragen.ai embed"
msgstr "Vragen.ai embed"

#: blocks/embed/block.json
msgctxt "block description"
msgid ""
"Embed een Vragen.ai-deployment via de deployment-slug. Het build-type "
"(pagina, popup of popover) komt uit de deployment zelf."
msgstr ""
"Embed a Vragen.ai deployment by its slug. The build type (page, popup or "
"popover) comes from the deployment itself."

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "vragen"
msgstr "questions"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "ai"
msgstr "ai"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "chat"
msgstr "chat"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "zoeken"
msgstr "search"

#: blocks/embed/block.json
msgctxt "block keyword"
msgid "embed"
msgstr "embed"

